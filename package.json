{
  "name": "mock-exam-platform",
  "version": "1.0.0",
  "description": "Mock exam platform frontend for SEB flow testing",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run client\" \"npm run seb-server\"",
